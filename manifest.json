{
  "manifest_version": 3,
  "name": "Big Favorites Bar",
  "description": "Shows your bookmarks bar with 2x favicon icons and labels in a fast popup.",
  "version": "1.2.1",
  "permissions": [
    "bookmarks",
    "favicon",
    "storage"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Open Big Favorites",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "css": [
        "content-toolbar.css"
      ],
      "js": [
        "content-toolbar.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
